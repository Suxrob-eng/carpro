DATABASE_URL=postgresql://postgres:password@localhost:5432/carpro
SECRET_KEY=replace-with-a-secure-secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Media / static
MEDIA_URL=/media
MEDIA_ROOT=./media
STATIC_URL=/static
STATIC_ROOT=./static

# CORS: comma-separated origins or *
BACKEND_CORS_ORIGINS=http://localhost:3000

# Example: BACKEND_CORS_ORIGINS=https://example.com,http://localhost:3000